"""Sync all git annex repositories in your home directory"""
# TODO manually iterate over all remotes

import argparse
import logging
import re
import subprocess
from pathlib import Path
from typing import Dict, Literal

logging.basicConfig(level=logging.INFO, format='%(asctime)s - %(message)s')
logger = logging.getLogger(__name__)

PING_TIMEOUT = 3
host_status: Dict[str, Literal["online", "offline"]] = {}


def can_ping_remote(remote_url: str) -> bool:
    """Check if we can ping the remote host"""
    # Only handle SSH URLs
    ssh_pattern = r"^ssh://(?:(?P<user>[^@]+)@)?(?P<host>.+?):?/"
    match = re.match(ssh_pattern, remote_url)

    if not match:
        logger.info("Don't know how to ping host at remote url %s", remote_url)
        return False

    host = match.group("host")

    match host_status.get(host):
        case "offline":
            return False
        case "online":
            return True
        case None:
            pass

    result = subprocess.run(
        ["ping", "-c", "1", "-W", str(PING_TIMEOUT), host],
        capture_output=True,
        text=True,
    )

    if result.returncode != 0:
        logger.info("%s appears to be offline", host)
        host_status[host] = "offline"
        return False
    else:
        logger.info("%s appears to be online", host)
        host_status[host] = "online"
        return True


def main(remote: str, non_interactive: bool):
    if remote:
        logger.info("Syncing with remote '%s'", remote)
    else:
        logger.info("Syncing with all remotes")

    cmd = [
        "fd",
        "-0",
        "--exclude",
        str(Path.home() / ".cache"),
        "--exclude",
        str(Path.home() / "Library"),
        "--prune",
        "--hidden",
        "--full-path",
        str(Path.home() / ".*/.git/annex$"),
        str(Path.home()),
    ]
    result = subprocess.run(cmd, capture_output=True, text=True, check=True, cwd=Path.home())
    paths = sorted(result.stdout.strip().split("\0"))

    if not paths:
        logger.info("No git-annex repositories found")
        return

    logger.info("Found %d git-annex repositories", len(paths))

    for annex_sub_dir in paths:
        annex = str(Path(annex_sub_dir).parent.parent)
        if remote:
            result = subprocess.run(
                ["git", "-C", annex, "remote", "get-url", remote],
                capture_output=True,
                text=True,
            )
            if result.returncode != 0:
                logger.info("git-annex at '%s': No remote named '%s', skipping", annex, remote)
                continue

            remote_url = result.stdout.strip()
            if not can_ping_remote(remote_url):
                logger.info("git-annex at '%s': Remote '%s' offline, skipping", annex, remote)
                continue
            logger.info("git-annex at '%s': Remote %s is reachable", annex, remote)

        logger.info("git-annex at '%s': Starting sync", annex)

        # Prefer pull over push because other remotes might be offline
        cmd = ["git", "annex", "sync", "--content", "--no-commit", "--no-push"]
        if remote:
            cmd = [*cmd, remote]

        logger.info("Running the following command inside %s:", annex)
        logger.info(" ".join(cmd))

        result = subprocess.run(cmd, cwd=annex)
        if result.returncode != 0:
            if remote:
                logger.error("git-annex at '%s' and remote '%s': not ok", annex, remote)
            else:
                logger.error("git-annex at '%s': not ok", annex)
            if non_interactive:
                logger.info("Non-interactive mode: continuing automatically")
                continue
            try:
                input("Continue? C-c to quit> ")
            except KeyboardInterrupt:
                return

        if remote:
            logger.error("git-annex at '%s' and remote '%s': ok", annex, remote)
        else:
            logger.error("git-annex at '%s': ok", annex)


if __name__ == "__main__":
    parser = argparse.ArgumentParser(
        description="Sync all git annex repositories in your home directory"
    )
    parser.add_argument("remote", nargs="?", help="Remote to sync with (optional)")
    parser.add_argument(
        "--non-interactive",
        action="store_true",
        help="Skip prompts and continue automatically)",
    )
    args = parser.parse_args()
    main(args.remote, args.non_interactive)
