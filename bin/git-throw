# git throw throws your repository to another computer on the same network
#
# TODO detect if annex, otherwise skip `git annex sync`
# TODO make this work even if annex isn't enabled. We can't push if the remote
# repository doesn't allow it. Some additional git settings might be necessary.

import argparse
import os
import re
import subprocess
from pathlib import Path
import functools

run = functools.partial(subprocess.run, check=True)


def main():
    """Push git repository to a remote repository, create the repository on the remote target, if needed."""
    parser = argparse.ArgumentParser(
        description="Push git repository to a remote repository, "
        "create the repository on the remote target, if needed"
    )
    parser.add_argument("remote")
    remote = parser.parse_args().remote
    # Only works if at home
    dir = f"~/{Path.cwd().relative_to(Path.home())}"
    print(f"Using path '{dir}' for remote repository directory")

    remote_name = re.sub(r"\.local$", "", remote)
    print(f"Setting remote name for remote '{remote}' to '{remote_name}'")

    try:
        run(["git", "remote", "get-url", remote_name])
    except Exception:
        print(f"Remote with name '{remote_name}' already exists")
        print("Still running git annex sync...")
    else:
        remote_url = f"ssh://{os.environ['USER']}@{remote}/{dir}"

        print(f"Using address '{remote_url}' for remote '{remote}'")

        print(f"SSH'ing into remote '{remote}' to create repository at path '{dir}'")
        run(["ssh", remote, f"git init {dir}"])
        run(["git", "remote", "add", remote_name, remote_url])

    subprocess.run(["git", "annex", "sync"], check=True)


if __name__ == "__main__":
    main()
